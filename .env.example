APP_NAME=PHARMAGNOSTIC AI
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:TU_CONTRASENA@localhost:5432/pharmagnostic_ai
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=pharmagnostic_ai
DATABASE_USER=postgres
DATABASE_PASSWORD=TU_CONTRASENA
FRONTEND_URL=http://localhost:5173
SECRET_KEY=change-this-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
# Audio clínico y transcripción
AUDIO_STORAGE_DIR=storage/audios
AUDIO_ALLOWED_FORMATS=webm,wav,mp3,ogg,m4a,mpeg
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# Base farmacológica / RAG (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.15
PHARMACOLOGICAL_FILES_PATH=storage/pharmacological
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_NAME=Administrador
INITIAL_ADMIN_LAST_NAME=Principal
INITIAL_ADMIN_EMAIL=admin@pharmagnostic.com
INITIAL_ADMIN_PASSWORD=123456
